{
  "name": "@validation-os/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "validation-os code monorepo: the DataProvider seam, derivation module, adapters, API, and dashboard that ship as npm packages.",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "typecheck": "pnpm -r --filter \"./packages/**\" typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r --filter \"./packages/**\" exec rm -rf dist",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
