# OS noise
.DS_Store

# Scratch
*.bak

# Personal tooling — the dashboard views my registry, not part of the
# published repo.
dashboard/

# The live register is local-only by default; the un-ignored records below
# are deliberately published as worked examples (registry/README.md).
registry/assumptions/*
!registry/assumptions/ASM-001.md
!registry/assumptions/ASM-006.md
registry/experiments/*
!registry/experiments/EXP-001.md
!registry/experiments/EXP-002.md
registry/decisions/*
!registry/decisions/DEC-001.md
!registry/decisions/DEC-002.md
registry/terminology/*
!registry/terminology/TERM-001.md

# Raw evidence (transcripts, chat exports, identities) — local-only.
# Public register records reference these paths and stay anonymized.
registry/evidence/*
!registry/evidence/README.md

# Local-only git hooks (consumer-side automation)
.git/hooks/*
!.git/hooks/*.sample
__pycache__/
