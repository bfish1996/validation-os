{
  "name": "@validation-os/adapter-firestore",
  "version": "0.15.1",
  "description": "Firestore (Admin SDK) DataProvider adapter for validation-os — the first nosql-family backend. Version-guarded writes.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@validation-os/core": "workspace:*"
  },
  "peerDependencies": {
    "firebase-admin": ">=12"
  },
  "devDependencies": {
    "firebase-admin": "^12.7.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bfish1996/validation-os.git",
    "directory": "packages/adapter-firestore"
  }
}
